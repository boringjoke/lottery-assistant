<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hotchpotch.lottery.notification.mapper.UserNotificationMapper">

    <resultMap id="BaseResultMap" type="com.hotchpotch.lottery.notification.entity.UserNotification">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="notification_type" property="notificationType"/>
        <result column="business_type" property="businessType"/>
        <result column="business_key" property="businessKey"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="read_status" property="readStatus"/>
        <result column="read_time" property="readTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectPageByUserId" resultMap="BaseResultMap">
        SELECT
            id,
            user_id,
            notification_type,
            business_type,
            business_key,
            title,
            content,
            read_status,
            read_time,
            create_time,
            update_time
        FROM user_notifications
        WHERE user_id = #{userId}
        ORDER BY
            CASE WHEN read_status = 'UNREAD' THEN 0 ELSE 1 END ASC,
            update_time DESC,
            id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

</mapper>
